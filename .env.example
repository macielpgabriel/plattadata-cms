APP_NAME="Plattadata CMS"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://plattadata.com
APP_TIMEZONE=America/Sao_Paulo
APP_KEY=base64:CHANGE_ME_WITH_A_RANDOM_32_CHAR_KEY

DB_HOST=localhost
DB_PORT=3306
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASS=sua_senha

DB_AUTO_PROVISION=false
DB_ROOT_HOST=localhost
DB_ROOT_PORT=3306
DB_ROOT_USER=root
DB_ROOT_PASS=

CMS_ADMIN_NAME=Administrador
CMS_ADMIN_EMAIL=admin@plattadata.com
CMS_ADMIN_PASSWORD=Plattadata#2026!

SESSION_NAME=cms_session
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax

PASSWORD_MIN_LENGTH=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
ADMIN_2FA_REQUIRED=true
ADMIN_OTP_LENGTH=6
ADMIN_OTP_TTL_MINUTES=10
SECURITY_HSTS=true
SECURITY_CSP="default-src 'self'; script-src 'self' 'nonce-{nonce}' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https:; frame-src https://www.google.com; connect-src 'self' https:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"

CHECK_PWNED_PASSWORDS=true

RL_CNPJ_PUBLIC_PER_MINUTE=20
RL_CNPJ_AUTH_USER_PER_MINUTE=60
RL_CNPJ_AUTH_IP_PER_MINUTE=120

LGPD_AUDIT_ENABLED=true
LGPD_RETENTION_ENABLED=true
RETENTION_COMPANY_QUERY_LOGS_DAYS=180
RETENTION_COMPANY_SOURCE_PAYLOADS_DAYS=180
RETENTION_COMPANY_SNAPSHOTS_DAYS=365
RETENTION_EMAIL_LOGS_DAYS=365
RETENTION_RATE_LIMITS_DAYS=7
RETENTION_LGPD_AUDIT_LOGS_DAYS=365

CNPJ_PROVIDER=brasilapi
CNPJ_API_BASE=https://brasilapi.com.br/api/cnpj/v1
CNPJ_FALLBACK_CHAIN=brasilapi,receitaws,cnpjws,opencnpj
CNPJ_HTTP_TIMEOUT=10
CNPJ_ALLOWED_HOSTS=brasilapi.com.br,www.receitaws.com.br,api.cnpj.ws,opencnpj.org,servicodados.ibge.gov.br,viacep.com.br
CNPJ_REFRESH_USER_COOLDOWN_DAYS=15
CNPJ_REFRESH_RATE_LIMIT_PER_HOUR=10
CNPJ_AUTO_REFRESH_MIN_DAYS=7
CNPJ_AUTO_REFRESH_LOCK_SECONDS=21600

CACHE_DRIVER=file
CACHE_REDIS_HOST=127.0.0.1
CACHE_REDIS_PORT=6379
CACHE_REDIS_PASSWORD=
CACHE_REDIS_DATABASE=0
CACHE_REDIS_PREFIX=cms_cache_
CACHE_MEMCACHED_HOST=127.0.0.1
CACHE_MEMCACHED_PORT=11211
CACHE_MEMCACHED_USERNAME=
CACHE_MEMCACHED_PASSWORD=
CACHE_MEMCACHED_PREFIX=cms_cache_

ADMIN_EMAIL=contato@plattadata.com
MAIL_ENABLED=true
MAIL_FROM_NAME="Plattadata CMS"
MAIL_FROM_ADDRESS=contato@plattadata.com

MAIL_MAILER=smtp
MAIL_SMTP_HOST=smtp.hostinger.com
MAIL_SMTP_PORT=465
MAIL_SMTP_USERNAME=contato@plattadata.com
MAIL_SMTP_PASSWORD=
MAIL_SMTP_ENCRYPTION=ssl
MAIL_SMTP_FROM_NAME="Plattadata CMS"

MAIL_IMAP_HOST=imap.hostinger.com
MAIL_IMAP_PORT=993
MAIL_IMAP_ENCRYPTION=ssl

PORTAL_TRANSPARENCIA_TOKEN=

BRAPI_URL=https://brapi.dev/api
BRAPI_TOKEN=

API_KEY=

GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://seudominio.com/auth/google/callback
