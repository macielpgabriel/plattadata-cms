<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Redirecionar arquivos estáticos para a pasta public/
    RewriteRule ^css/(.*)$ public/css/$1 [L]
    RewriteRule ^js/(.*)$ public/js/$1 [L]
    RewriteRule ^images/(.*)$ public/images/$1 [L]
    RewriteRule ^img/(.*)$ public/img/$1 [L]
    RewriteRule ^fonts/(.*)$ public/fonts/$1 [L]
    RewriteRule ^font/(.*)$ public/font/$1 [L]
    RewriteRule ^manifest\.json$ public/manifest.json [L]
    
    # Redireciona tudo para o public/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ public/index.php [QSA,L]
</IfModule>

# Cache para assets estáticos (CSS, JS, imagens, fontes)
<IfModule mod_expires.c>
    ExpiresActive On
    
    # CSS e JS - cache longo (1 ano)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    
    # Imagens - cache longo (1 ano)
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # Fontes - cache longo (1 ano)
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # HTML e PHP - sem cache (sempre dinâmico)
    ExpiresByType text/html "access plus 0"
    ExpiresByType application/x-httpd-php "access plus 0"
</IfModule>

# Compressão gzip para CSS, JS, HTML
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>
