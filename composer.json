{
    "name": "plattadata/cms",
    "description": "CMS Empresarial para consulta de CNPJ",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "phpmailer/phpmailer": "^7.0"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "analyse": "phpstan analyse",
        "analyse:strict": "phpstan analyse --level=5"
    }
}
